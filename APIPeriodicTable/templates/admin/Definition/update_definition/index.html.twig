{% extends 'base.html.twig' %}

{% block title %}Hello UpdateDefinitionController!{% endblock %}

{% block body %}

    <section>
        <article>
            <div class="container">
                <h1 class="text-center my-5">Mise à jour de la définition</h1>
                {{ form(form) }}
            </div>
            {% if is_granted('ROLE_SUPER_ADMIN')%}
            <hr class="my-5">
            <article>
                <div class="container">
                    <h1 class="text-center my-5">Suppression de la définition</h1>
                    <div class="supprCata ">
                        <div>
                            <p>Attention, la suppression de la définition sera définitive et il ne pourra y avoir de retour en arrière possible.</p>
                        </div>
                        <div>
                            <form method="post" action="{{ path('app_delete_definition', {id: app.request.attributes.get('id')}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-definition-' ~ app.request.attributes.get('id')) }}">
                                <button type="submit" class="btn btn-danger">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            </article>
            {% endif %}
        </article>
    </section>
{% endblock %}
